# Copia in .env e adatta i valori

# Porta esposta sul Raspberry (default 3001)
APP_PORT=3001

# URL pubblico del sito (schema + dominio, senza slash finale)
# Esempio: https://smashbash.tuodominio.it
CLIENT_ORIGIN=https://smashbash.tuodominio.it

# Solo se usi il profilo TLS con Caddy (docker compose --profile tls up -d)
DOMAIN=smashbash.tuodominio.it
